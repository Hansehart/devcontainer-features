{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "abandonments:recommended",
    ":configMigration",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "Europe/Berlin",
  "labels": ["Renovate"],
  "semanticCommits": "enabled",
  "semanticCommitScope": "deps",
  "pinDigests": true,
  "minimumReleaseAge": "3 days",
  "prBodyColumns": ["Package", "Type", "Update", "Change", "Age"],
  "prBodyDefinitions": {
    "Age": "{{#if newVersion}}{{{newVersionAgeInDays}}} days{{/if}}"
  },
  "vulnerabilityAlerts": {
    "addLabels": ["Security"]
  },
  "packageRules": [
    {
      "description": "Commit CI tooling bumps with the chore type to match this repo's commit history.",
      "matchManagers": ["github-actions", "custom.regex"],
      "semanticCommitType": "chore"
    },
    {
      "description": "Group GitHub Action updates into a single pull request.",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Label major updates so they get a deliberate review.",
      "matchUpdateTypes": ["major"],
      "addLabels": ["Breaking"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track the @devcontainers/cli version pinned in the test workflow's run step.",
      "managerFilePatterns": ["/^\\.github/workflows/[^/]+\\.ya?ml$/"],
      "matchStrings": ["@devcontainers/cli@(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "datasourceTemplate": "npm",
      "depNameTemplate": "@devcontainers/cli"
    }
  ]
}
